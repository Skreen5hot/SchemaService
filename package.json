{
  "name": "bibss",
  "version": "1.3.0-alpha.0",
  "description": "Brain-in-the-Box Schema Service — deterministic, client-side structural inference engine for CSV and JSON input",
  "type": "module",
  "main": "dist/kernel/index.js",
  "types": "dist/kernel/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:tests": "tsc -p tsconfig.test.json",
    "start": "node dist/kernel/index.js",
    "test": "npm run build:tests && node dist-tests/tests/run-tests.js",
    "test:purity": "npm run build:tests && node dist-tests/scripts/ensure-kernel-purity.js",
    "clean": "rimraf dist dist-tests",
    "build:site": "node scripts/build-site.mjs"
  },
  "keywords": [
    "schema-inference",
    "csv",
    "json",
    "deterministic",
    "edge-computing",
    "structural-inference",
    "json-schema"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "homepage": "",
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.1",
    "@types/papaparse": "^5.5.2",
    "esbuild": "^0.27.3",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "papaparse": "^5.5.3"
  }
}
